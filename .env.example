# ICB Platform — environment variable contract (WO v4.12 §3.6).
# Copy to backend/.env and edit. Two variables are REQUIRED; everything else has
# a safe local-dev default. The app refuses to boot if a required var is missing.
# NEVER commit a real .env — only this example file is tracked.

# ── Deployment ───────────────────────────────────────────────────────────────
DEPLOYMENT_MODE=on_prem            # cloud | on_prem   (surfaces in the UI footer)
APP_PORT=8000

# ── Database (REQUIRED) ────────────────────────────────────────────────────────
# PostgreSQL only. This dev machine uses PostgreSQL 18 on port 5432.
# Adjust host/port/credentials to your environment.
DATABASE_URL=postgresql+psycopg://icb_app:icb_app_dev@localhost:5432/icb

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_PROVIDER=email_password       # email_password | ldap   (ldap = Phase 3 stub)
SESSION_SECRET=change-me-to-a-long-random-string    # REQUIRED — cookie signing key

# ── Storage (Phase 3 expands this) ─────────────────────────────────────────────
FILE_STORE=./local_files

# ── Outbound integrations ──────────────────────────────────────────────────────
SMTP_URL=                          # empty = no email sent (dev mode)
SAP_ENABLED=false
SAP_BASE_URL=

# ── Branch defaults ────────────────────────────────────────────────────────────
DEFAULT_BRANCH_CODE=JHB

# ── Feature flags (Phase 4+) ────────────────────────────────────────────────────
FEATURE_NEW_CALCULATOR=false

# ── Frontend (React build served by FastAPI at /mes-app/) ──────────────────────
# Defaults to <repo>/frontend/dist; uncomment to override.
# FRONTEND_DIST=

# ── AI Help assistant (optional) ───────────────────────────────────────────────
# Without a key the floating Help button is hidden.
ANTHROPIC_API_KEY=

# ── CORS (comma-separated string or JSON array) ────────────────────────────────
# Defaults to localhost:8000/5173/4173 (+127.0.0.1). Override per environment.
# ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
