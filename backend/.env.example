# ICB MES — backend environment template (referenced by app/config.py).
#
# Copy to backend/.env and fill in. Two vars are REQUIRED (the app refuses to boot
# without them); everything else has a safe local-dev default.
#
# ⚠ DEPENDENCIES: run `pip install -r requirements.txt` INTO the venv
#   (e.g. `.venv/Scripts/python.exe -m pip install -r requirements.txt`), NOT the
#   system Python. A package present in system Python but missing from the venv is
#   lazy-imported with a silent fallback, so the feature ends up silently disabled —
#   exactly how v4.38 WhatsApp shipped non-functional (twilio undeclared). See WO v4.38.1.

# ── REQUIRED (no default — app won't boot without these) ───────────────────────
DATABASE_URL=postgresql+psycopg://icb_app:CHANGE_ME@localhost:5432/icb
SESSION_SECRET=CHANGE_ME_to_a_long_random_string

# ── Deployment ──
DEPLOYMENT_MODE=cloud            # cloud | on_prem  (surfaces in the UI footer)
APP_PORT=8000
AUTH_PROVIDER=email_password     # email_password | ldap (ldap = Phase 3)
DEFAULT_BRANCH_CODE=JHB

# ── Storage ──
FILE_STORE=./local_files         # feedback screenshots land in <FILE_STORE>/feedback

# ── Email (optional; empty = no email sent / dev mode) ──
SMTP_URL=                        # smtp://user:pass@host:port  or  smtp+ssl://user:pass@host:465

# ── SAP (read-only integration; Phase 2+) ──
SAP_ENABLED=false
SAP_BASE_URL=

# ── AI: Help assistant + Feedback classifier (optional; unset = AI off, app still works) ──
ANTHROPIC_API_KEY=               # unset → Help button hidden + feedback classify is a graceful no-op
ANTHROPIC_FEEDBACK_MODEL=        # optional model override; falls back to claude-haiku-4-5

# ── Feedback Portal (WO v4.38; all optional — empty = that channel is skipped) ──
FEEDBACK_NOTIFY_EMAIL=           # where feedback tickets are emailed (the BA)
FEEDBACK_NOTIFY_WHATSAPP=        # WhatsApp ping target, e.g. whatsapp:+27821234567
                                 #   (this is the var the code reads — NOT TWILIO_WHATSAPP_TO)
FEEDBACK_SCREENSHOT_DIR=         # override blob dir; empty = <FILE_STORE>/feedback
# Twilio WhatsApp delivery — needs `twilio` in the venv (see DEPENDENCIES note above).
# All three must be set OR the ping is skipped (with FEEDBACK_NOTIFY_WHATSAPP as the target).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=            # Twilio WhatsApp sender, e.g. whatsapp:+14155238886

# ── Feature flags ──
FEATURE_NEW_CALCULATOR=false

# ── CORS (comma-separated or JSON array; default covers localhost dev ports) ──
# ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
